NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# dummy | live (live must run on server — browser keeps dummy)
NEXT_PUBLIC_ODOO_MODE=dummy
NEXT_PUBLIC_RAGFLOW_MODE=dummy
NEXT_PUBLIC_RAGFLOW_DATASET_ID=cms-contracts

# Do NOT put Odoo password / RAGFlow API key in NEXT_PUBLIC_* (browser).
# Store those in server env / Supabase secrets:
#   ODOO_URL, ODOO_DB, ODOO_USERNAME, ODOO_API_KEY
#   RAGFLOW_URL, RAGFLOW_API_KEY
