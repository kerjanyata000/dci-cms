NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# dummy | live — live calls /api/* on Next.js server (credentials stay server-side)
NEXT_PUBLIC_ODOO_MODE=live
NEXT_PUBLIC_RAGFLOW_MODE=live
NEXT_PUBLIC_RAGFLOW_DATASET_ID=your-ragflow-dataset-uuid

# --- Server-only (no NEXT_PUBLIC_ prefix) ---

# Odoo XML-RPC / JSON-RPC
ODOO_URL=https://YOUR_INSTANCE.odoo.com
ODOO_DB=your-db-name
ODOO_USERNAME=you@company.com
ODOO_API_KEY=your-odoo-api-key

# RAGFlow cloud (base URL from cloud dashboard, e.g. https://xxx.ragflow.io)
RAGFLOW_URL=https://YOUR_RAGFLOW_CLOUD_HOST
RAGFLOW_API_KEY=your-ragflow-api-key
# UUID dataset from RAGFlow UI (Knowledge Base → dataset → copy id)
RAGFLOW_DATASET_ID=your-ragflow-dataset-uuid

# Do NOT put Odoo password / RAGFlow API key in NEXT_PUBLIC_* (browser).
